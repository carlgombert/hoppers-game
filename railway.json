{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS"
  },
  "services": {
    "hoppers-server": {
      "source": {
        "root": "server"
      },
      "build": {
        "watchPatterns": ["server/src/**"]
      },
      "deploy": {
        "startCommand": "npm start",
        "restartPolicyType": "ON_FAILURE"
      }
    },
    "hoppers-client": {
      "source": {
        "root": "client"
      },
      "build": {
        "watchPatterns": ["client/src/**"]
      },
      "deploy": {
        "startCommand": "npm start",
        "restartPolicyType": "ON_FAILURE"
      }
    }
  }
}
